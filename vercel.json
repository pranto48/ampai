{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR_BACKEND_URL/api/$1"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "^/(index|login|chat|settings|admin|memory-explorer|ai-models|spa)\\.html$",
      "dest": "/frontend/$1.html"
    },
    {
      "src": "^/(app|auth|admin|memory-explorer|spa)\\.js$",
      "dest": "/frontend/$1.js"
    },
    {
      "src": "^/style\\.css$",
      "dest": "/frontend/style.css"
    }
  ]
}
