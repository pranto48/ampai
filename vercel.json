{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR_BACKEND_URL/api/$1"
    }
  ],
  "routes": [
    {
      "handle": "filesystem",
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "SUPABASE_URL": "https://<YOUR-PROJECT>.supabase.co",
    "SUPABASE_ANON_KEY": "public-anon-key"
  }
}