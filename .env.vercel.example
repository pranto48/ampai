# Frontend-side values (safe for browser use)
# Prefer the new publishable key from Supabase over legacy anon key.
NEXT_PUBLIC_SUPABASE_URL=https://<YOUR-PROJECT>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<YOUR_KEY>

# Backend base URL used by rewrite destination in vercel.json
# Example: https://api.yourdomain.com
BACKEND_PUBLIC_URL=https://YOUR_BACKEND_URL
