# Supabase Project Settings -> API
SUPABASE_URL=https://<YOUR-PROJECT>.supabase.co
SUPABASE_ANON_KEY=public-anon-key

# Supabase Project Settings -> Database -> Connection string (pooling URL recommended)
# Example: postgresql://postgres.<PROJECT>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<PROJECT>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres

# Redis for cloud previews (Upstash/Redis Cloud). If not provided, app may default to local redis URL.
REDIS_URL=redis://default:<PASSWORD>@<HOST>:<PORT>

# Auth / app secrets
JWT_SECRET=dyad-preview-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=P@ssw0rd
USER_USERNAME=user
USER_PASSWORD=user123
