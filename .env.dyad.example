# Supabase Project Settings -> API
SUPABASE_URL=https://<YOUR-PROJECT>.supabase.co
SUPABASE_ANON_KEY=public-anon-key

# Supabase Project Settings -> Database -> Connection string -> Connection string (use the PostgreSQL URL)
# Example: postgresql://postgres:password@db.<PROJECT>.supabase.co:5432/postgres
DATABASEURL=postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres

# Other required secrets (copy from .env.example)
JWT_SECRET=dyad-preview-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123